  "projectName": "Dench",
  "projectDescription": "Dench is a shared workspace that gives AI agents tasks, context, rules, and a human approval path before they touch your work.",
  "theme": "luma",
  "primaryColor": "#040404",
  "lightColor": "#7c7474",
  "darkColor": "#272625",
  "navigation": {
    "tabs": [
      {
        "tab": "Agent Workspace",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
