  "keyFeatures": [
    "Agent task board — agents claim and complete tasks from a shared workspace",
    "Context store — project notes, rules, and decisions kept in one place for agents",
    "Human approval gates — require a human check before deploys, production changes, or risky actions",
    "dench-cli — agent-facing CLI for login, task management, logging, and approvals",
    "External tool brokering — agents run Composio-backed tools (GitHub, Slack, Gmail, Stripe, etc.) through Dench with approval enforcement",
    "Gateway API keys — manage keys for workspace and sandbox access"
  ],
  "publicApiSurface": [
    "dench login --name <name> --kind <kind>",
    "dench sessions",
    "dench use <session-key-or-workspace-slug>",
    "dench logout",
    "dench context",
    "dench status [--mine]",
    "dench tasks",
    "dench task create <title> --description --priority --risk",
    "dench claim <taskId>",
    "dench log <message>",
    "dench approval request <message>",
    "dench approval approve <approvalId> --evidence",
    "dench approval reject <approvalId> --evidence",
    "dench apps",
    "dench tool status [toolkit]",
    "dench tool connect <toolkit>",
    "dench tool search <query>",
    "dench tool run <composio_tool_slug> --args"
  ]
}
